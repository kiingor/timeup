# ---- Database ----
# Local dev (native PostgreSQL 16). On the VPS this points at the docker postgres service.
DATABASE_URL="postgresql://timeup_app:timeup@localhost:5432/timeup?schema=public"

# ---- Auth (NextAuth v5) ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="CHANGE_ME_base64_32_bytes"

# ---- Secrets encryption (AES-256-GCM for Softcom client_secret at rest) ----
# Must be 32 bytes, base64. Generate with the same command as AUTH_SECRET.
MASTER_ENCRYPTION_KEY="CHANGE_ME_base64_32_bytes"

# ---- Internal sync trigger (shared secret between web and worker) ----
INTERNAL_SYNC_SECRET="CHANGE_ME_random_string"

# ---- App ----
TZ="America/Sao_Paulo"
NEXT_PUBLIC_APP_NAME="TimeUp"

# ---- Softcom (defaults / fallback only; real config is per-tenant in the DB) ----
# Set SOFTCOM_MOCK=1 to develop the integration without hitting the live API.
SOFTCOM_MOCK="0"
